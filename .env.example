# Route Planner — variables d'environnement
# Copiez ce fichier en .env et adaptez les valeurs.
# Le .env est charge automatiquement au demarrage du CLI et de l'app web
# (si python-dotenv est installe).

# ── Assistant IA ───────────────────────────────────────────────
# Provider par defaut : anthropic. Utilisez --ai-provider vllm|openai|anthropic
# (CLI) ou le selecteur "Provider IA" (web) pour choisir.

# --- vLLM : serveur local compatible OpenAI (ex. Qwen 3.5) ---
# Lancer le serveur, p.ex. :
#   vllm serve Qwen/Qwen3.5-32B-Instruct --port 8000
# puis :
#   route-planner --ai-provider vllm --ai-prompt "..." --guide --ai-enrich
VLLM_URL=http://localhost:8000/v1
VLLM_MODEL=Qwen/Qwen3.5-32B-Instruct
VLLM_API_KEY=EMPTY

# --- OpenAI (optionnel) ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# --- Anthropic / Claude (optionnel) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8

# ── Services de routage / POI (optionnels) ─────────────────────
# OVERPASS_URL=https://overpass-api.de/api/interpreter
# VALHALLA_URL=http://localhost:8002
# GRAPHHOPPER_URL=https://graphhopper.com/api/1
# GRAPHHOPPER_API_KEY=
# BROUTER_URL=https://brouter.de/brouter
# ROUTE_PLANNER_CACHE_PATH=
